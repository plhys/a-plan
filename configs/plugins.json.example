{
  "plugins": {
    "api-potluck": {
      "enabled": false,
      "description": "API 大锅饭 - Key 管理和用量统计插件"
    },
    "default-auth": {
      "enabled": true,
      "description": "默认 API Key 认证插件（内置）"
    },
    "model-usage-stats": {
      "enabled": false,
      "description": "模型用量统计插件"
    }
  }
}
